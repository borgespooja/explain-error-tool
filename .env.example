# Copy this file to .env and fill in values. The CLI auto-loads .env at startup.

# LLM provider. Supported: anthropic
EXPLAIN_ERROR_PROVIDER=anthropic

# Optional: override the default model for the chosen provider.
# Leave blank to use the provider's built-in default.
EXPLAIN_ERROR_MODEL=

# Provider API keys. Only the one matching EXPLAIN_ERROR_PROVIDER is required.
ANTHROPIC_API_KEY=

# Request behavior
EXPLAIN_ERROR_TIMEOUT_SECONDS=30
EXPLAIN_ERROR_MAX_LOG_CHARS=16000
